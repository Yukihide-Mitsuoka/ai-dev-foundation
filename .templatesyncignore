# Files the template-sync workflow must NEVER overwrite in downstream repos —
# everything a project customizes. Rules/workflows/skills DO sync (that's the point).
src/**
tests/**
docs/**
profiles/**
CLAUDE.md
README.md
Makefile
.env.example
.ai/mission.md
.ai/decision-log.md
.github/CODEOWNERS
.github/governance/repository.json
.templatesyncignore

# Foundation-owned documentation is the only synchronized docs namespace. This Action
# passes entries to `git reset --`, so exclusions use Git pathspec `:!` syntax rather
# than `.gitignore` negation. Keep them last so broad rules do not re-exclude the files.
:!docs/foundation/
:!docs/foundation/**
